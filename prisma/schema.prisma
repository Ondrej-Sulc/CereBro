  PROCESSING
  COMPLETED
  FAILED
}

enum BotJobType {
  NOTIFY_WAR_VIDEO
  DISTRIBUTE_WAR_PLAN
  UPDATE_MEMBER_ROLES
  NOTIFY_DEATH_VIDEO
  DISTRIBUTE_DEFENSE_PLAN
  LEAVE_GUILD
  ASSIGN_SUPPORTER_ROLE
}

enum QuestPlanStatus {
