generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AbilityCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String
  abilities   Ability[] @relation("AbilityToAbilityCategory")
}

model Ability {
  id                 Int                   @id @default(autoincrement())
  name               String                @unique
  description        String?
  emoji              String?
  iconUrl            String?
  gameGlossaryTermId String?               @unique
  gameGlossaryTerm   GameGlossaryTerm?     @relation(fields: [gameGlossaryTermId], references: [id])
  champions          ChampionAbilityLink[]
  categories         AbilityCategory[]     @relation("AbilityToAbilityCategory")
}

model Champion {
  id                           Int                          @id @default(autoincrement())
  name                         String                       @unique
  slug                         String?                      @unique
  shortName                    String
  gameId                       String?                      @unique
  class                        ChampionClass
  releaseDate                  DateTime
  obtainable                   String[]
  images                       Json
  discordEmoji                 String?
  fullAbilities                Json
  isPlayable                   Boolean                      @default(true)
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt
  attacks                      Attack[]
  abilities                    ChampionAbilityLink[]
  abilityTexts                 ChampionAbilityText[]
  abilityCurves                ChampionAbilityCurve[]
  synergyProviderFor           ChampionAbilitySynergy[]
  prestigeData                 ChampionPrestige[]
  stats                        ChampionStats[]
  duels                        Duel[]
  placedPrefights              FightPrefight[]
  questSelectedAsCounter       PlayerQuestEncounter[]       @relation("PlayerSelectedCounter")
  questSynergyPicks            PlayerQuestSynergyChampion[]
  questDefenderEncounters      QuestEncounter[]
  roster                       Roster[]
  seasonBans                   SeasonBan[]
  warBans                      WarBan[]
  defensePlacements            WarDefensePlacement[]
  extraAssignments             WarExtraChampion[]
  asAttacker                   WarFight[]                   @relation("AttackerRelation")
  asDefender                   WarFight[]                   @relation("DefenderRelation")
  tags                         Tag[]                        @relation("ChampionToTag")
  questRecommendedInEncounters QuestEncounter[]             @relation("EncounterRecommendedChampions")
}

model ChampionPrestige {
  id         Int      @id @default(autoincrement())
  championId Int
  rarity     Int
  rank       Int
  sig        Int
  prestige   Int
  champion   Champion @relation(fields: [championId], references: [id], onDelete: Cascade)

  @@unique([championId, rarity, rank, sig])
  @@index([championId])
}

model ChampionStats {
  id                      Int      @id @default(autoincrement())
  championId              Int
  tierId                  String
  rarity                  Int?
  rarityLabel             String?
  rank                    Int
  level                   Int?
  challengeRating         Int
  health                  Int?
  attack                  Int?
  healthRating            Int?
  attackRating            Int?
  prestige                Int?
  armorRating             Int?
  armorPenetration        Int?
  criticalRating          Int?
  criticalResistance      Int?
  criticalDamageRating    Int?
  blockProficiency        Int?
  blockPenetration        Int?
  specialDamageMultiplier Float?
  energyResistance        Int?
  physicalResistance      Int?
  baseAbilityIds          String[]
  sigAbilityIds           String[]
  champion                Champion @relation(fields: [championId], references: [id], onDelete: Cascade)

  @@unique([tierId, rank])
  @@index([championId])
  @@index([rarity, rank])
  @@index([challengeRating])
}

model ChampionAbilityText {
  id         Int      @id @default(autoincrement())
  championId Int
  sourceId   String
  group      String
  title      String?
  sortOrder  Int
  template   Json
  champion   Champion @relation(fields: [championId], references: [id], onDelete: Cascade)

  @@unique([championId, sourceId])
  @@index([championId, group])
}

model ChampionAbilityCurve {
  id         Int       @id @default(autoincrement())
  championId Int?
  curveId    String    @unique
  kind       String
  formula    String
  params     Json
  minSig     Int?
  maxSig     Int?
  champion   Champion? @relation(fields: [championId], references: [id], onDelete: Cascade)
}

model GameGlossaryTerm {
  id          String   @id
  name        String
  description String?
  category    String?
  raw         Json?
  iconUrl     String?
  ability     Ability?
}

model Duel {
  id                   Int        @id @default(autoincrement())
  playerName           String
  rank                 String?
  championId           Int
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  status               DuelStatus @default(ACTIVE)
  submittedByDiscordId String?
  source               DuelSource @default(GUIA_MTC)
  champion             Champion   @relation(fields: [championId], references: [id], onDelete: Cascade)

  @@unique([championId, playerName])
  @@index([championId])
}

model Tag {
  id                        Int              @id @default(autoincrement())
  name                      String
  category                  String
  highlightedInPlans        WarDefensePlan[]
  attackTactics             WarTactic[]      @relation("AttackTactic")
  defenseTactics            WarTactic[]      @relation("DefenseTactic")
  champions                 Champion[]       @relation("ChampionToTag")
  questRequiredInEncounters QuestEncounter[] @relation("EncounterRequiredTags")
  questRequiredInPlans      QuestPlan[]      @relation("QuestRequiredTags")

  @@unique([name, category])
}

model ChampionAbilityLink {
  id               Int                      @id @default(autoincrement())
  type             AbilityLinkType
  source           String?
  championId       Int
  abilityId        Int
  ability          Ability                  @relation(fields: [abilityId], references: [id], onDelete: Cascade)
  champion         Champion                 @relation(fields: [championId], references: [id], onDelete: Cascade)
  synergyChampions ChampionAbilitySynergy[]

  @@unique([championId, abilityId, type, source])
  @@index([championId])
  @@index([abilityId])
}

model ChampionAbilitySynergy {
  id                    Int                 @id @default(autoincrement())
  championAbilityLinkId Int
  championId            Int
  championAbilityLink   ChampionAbilityLink @relation(fields: [championAbilityLinkId], references: [id], onDelete: Cascade)
  champion              Champion            @relation(fields: [championId], references: [id], onDelete: Cascade)

  @@unique([championAbilityLinkId, championId])
  @@index([championAbilityLinkId])
  @@index([championId])
}

model Attack {
  id         Int        @id @default(autoincrement())
  type       AttackType
  championId Int
  champion   Champion   @relation(fields: [championId], references: [id], onDelete: Cascade)
  hits       Hit[]

  @@unique([championId, type])
  @@index([championId])
}

model Hit {
  id         Int      @id @default(autoincrement())
  properties String[]
  attackId   Int
  attack     Attack   @relation(fields: [attackId], references: [id], onDelete: Cascade)

  @@index([attackId])
}

model Schedule {
  id                String            @id @default(cuid())
  name              String
  frequency         ScheduleFrequency
  time              String
  command           String?
  message           String?
  target_channel_id String?
  target_user_id    String?
  is_active         Boolean           @default(true)
  day               String?
  interval          String?
  unit              String?
  last_run          DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model AQState {
  channelId String   @id
  state     Json
  updatedAt DateTime @updatedAt
}

model BotUser {
  id                String            @id @default(cuid())
  discordId         String            @unique
  avatar            String?
  isBotAdmin        Boolean           @default(false)
  permissions       String[]          @default([])
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  activeProfileId   String?
  profiles          Player[]
  createdQuestPlans QuestPlan[]       @relation("QuestPlanCreators")
  supportDonations  SupportDonation[]
}

model Player {
  id                 String                      @id @default(cuid())
  discordId          String
  ingameName         String
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  championPrestige   Int?
  relicPrestige      Int?
  summonerPrestige   Int?
  allianceId         String?
  isBotAdmin         Boolean                     @default(false)
  timezone           String?
  isActive           Boolean                     @default(false)
  isTrustedUploader  Boolean                     @default(false)
  battlegroup        Int?
  isOfficer          Boolean                     @default(false)
  avatar             String?
  useDiscordAvatar   Boolean                     @default(true)
  botUserId          String?
  sentInvitations    AllianceMembershipRequest[] @relation("OfficerInvites")
  membershipRequests AllianceMembershipRequest[] @relation("PlayerRequests")
  placedPrefights    FightPrefight[]
  alliance           Alliance?                   @relation(fields: [allianceId], references: [id])
  botUser            BotUser?                    @relation(fields: [botUserId], references: [id], onDelete: Cascade)
  playerQuestPlans   PlayerQuestPlan[]
  prestigeHistory    PrestigeLog[]
  createdQuestPlans  QuestPlan[]                 @relation("QuestCreator")
  roster             Roster[]
  uploadTokens       UploadToken[]
  encounterVideos    QuestEncounterVideo[]
  defensePlacements  WarDefensePlacement[]
  extraChampions     WarExtraChampion[]
  playedInFights     WarFight[]                  @relation("PlayerInFight")
  submittedVideos    WarVideo[]                  @relation("SubmittedBy")
  supportDonations   SupportDonation[]

  @@unique([discordId, ingameName])
  @@index([discordId])
  @@index([allianceId])
}

model SupportDonation {
  id                      String    @id @default(cuid())
  amountMinor             Int
  currency                String
  status                  String
  stripeCheckoutSessionId String    @unique
  stripePaymentIntentId   String?
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  supporterName           String?
  supporterEmail          String?
  retentionState          String    @default("ACTIVE")
  anonymizedAt            DateTime?
  deletedAt               DateTime?
  consentRevoked          Boolean   @default(false)
  discordId               String?
  botUserId               String?
  playerId                String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  player                  Player?   @relation(fields: [playerId], references: [id], onDelete: SetNull)
  botUser                 BotUser?  @relation(fields: [botUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([playerId, createdAt])
  @@index([botUserId, createdAt])
  @@index([discordId, createdAt])
  @@index([stripeSubscriptionId])
  @@index([retentionState, anonymizedAt, deletedAt])
}

model PrestigeLog {
  id               Int      @id @default(autoincrement())
  summonerPrestige Int
  championPrestige Int
  relicPrestige    Int
  createdAt        DateTime @default(now())
  playerId         String
  player           Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

model Alliance {
  id                     String                      @id @default(cuid())
  guildId                String?
  name                   String
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  enabledFeatureCommands String[]                    @default([])
  createAqThread         Boolean                     @default(false)
  battlegroup1Role       String?
  battlegroup2Role       String?
  battlegroup3Role       String?
  officerRole            String?
  canUploadFiles         Boolean                     @default(false)
  warVideosChannelId     String?
  battlegroup1ChannelId  String?
  battlegroup2ChannelId  String?
  battlegroup3ChannelId  String?
  battlegroup1Color      String                      @default("#ef4444")
  battlegroup2Color      String                      @default("#22c55e")
  battlegroup3Color      String                      @default("#3b82f6")
  playerColorPalette     String                      @default("HIGH_CONTRAST")
  tag                    String?                     @unique
  description            String?
  inviteOnly             Boolean                     @default(false)
  linkCode               String?                     @unique
  linkCodeExpires        DateTime?
  deathChannelId         String?
  activeDefensePlanId    String?                     @unique
  removeMissingMembers   Boolean                     @default(false)
  aqReminderSettings     AQReminderSettings?
  aqSchedules            AQSchedule[]
  aqSkip                 AQSkip?
  activeDefensePlan      WarDefensePlan?             @relation("ActiveDefensePlan", fields: [activeDefensePlanId], references: [id])
  config                 AllianceConfig?
  membershipRequests     AllianceMembershipRequest[]
  members                Player[]
  wars                   War[]
  defensePlans           WarDefensePlan[]
}

model AllianceMembershipRequest {
  id         String                  @id @default(cuid())
  status     MembershipRequestStatus @default(PENDING)
  type       MembershipRequestType
  allianceId String
  playerId   String
  inviterId  String?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  alliance   Alliance                @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  inviter    Player?                 @relation("OfficerInvites", fields: [inviterId], references: [id])
  player     Player                  @relation("PlayerRequests", fields: [playerId], references: [id], onDelete: Cascade)

  @@index([allianceId])
  @@index([playerId])
}

model AQReminderSettings {
  id                      String   @id @default(cuid())
  allianceId              String   @unique
  finalReminderEnabled    Boolean  @default(true)
  section1ReminderEnabled Boolean  @default(true)
  section2ReminderEnabled Boolean  @default(true)
  finalPingTime           String   @default("11:00")
  section1PingTime        String   @default("11:00")
  section2PingTime        String   @default("18:00")
  alliance                Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
}

model AllianceConfig {
  id         String   @id @default(cuid())
  sheetId    String?
  allianceId String   @unique
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
}

model AQSchedule {
  id          String   @id @default(cuid())
  allianceId  String
  battlegroup Int
  dayOfWeek   Int
  time        String
  aqDay       Int
  channelId   String
  roleId      String
  alliance    Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)

  @@unique([allianceId, battlegroup, aqDay])
}

model AQSkip {
  id         String   @id @default(cuid())
  allianceId String   @unique
  skipUntil  DateTime
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
}

model Roster {
  id             String   @id @default(cuid())
  stars          Int
  rank           Int
  isAwakened     Boolean
  powerRating    Int?
  playerId       String
  championId     Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isAscended     Boolean  @default(false)
  ascensionLevel Int      @default(0)
  sigLevel       Int      @default(0)
  champion       Champion @relation(fields: [championId], references: [id], onDelete: Cascade)
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, championId, stars])
  @@index([playerId])
  @@index([championId])
}

model War {
  id             String             @id @default(cuid())
  season         Int
  warNumber      Int?
  warTier        Int
  enemyAlliance  String?
  createdAt      DateTime           @default(now())
  allianceId     String
  status         WarStatus          @default(PLANNING)
  mapType        WarMapType         @default(STANDARD)
  name           String?
  result         WarResult          @default(UNKNOWN)
  enemyDeaths    Int?
  alliance       Alliance           @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  bans           WarBan[]
  extraChampions WarExtraChampion[]
  fights         WarFight[]

  @@unique([allianceId, season, warNumber])
  @@index([allianceId])
}

model WarDefensePlan {
  id                String                @id @default(cuid())
  name              String
  mapType           WarMapType            @default(STANDARD)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  allianceId        String
  tacticId          String?
  highlightTagId    Int?
  tier              Int?
  activeForAlliance Alliance?             @relation("ActiveDefensePlan")
  placements        WarDefensePlacement[]
  alliance          Alliance              @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  highlightTag      Tag?                  @relation(fields: [highlightTagId], references: [id])
  tactic            WarTactic?            @relation(fields: [tacticId], references: [id])

  @@index([allianceId])
}

model WarDefensePlacement {
  id          String         @id @default(cuid())
  nodeId      Int
  defenderId  Int?
  playerId    String?
  planId      String
  battlegroup Int            @default(1)
  starLevel   Int?
  defender    Champion?      @relation(fields: [defenderId], references: [id])
  node        WarNode        @relation(fields: [nodeId], references: [id])
  plan        WarDefensePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  player      Player?        @relation(fields: [playerId], references: [id])

  @@unique([planId, battlegroup, nodeId])
  @@index([planId])
  @@index([playerId])
  @@index([defenderId])
  @@index([nodeId])
}

model SeasonBan {
  id         String   @id @default(cuid())
  season     Int
  minTier    Int?
  maxTier    Int?
  championId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  champion   Champion @relation(fields: [championId], references: [id], onDelete: Cascade)

  @@unique([season, minTier, maxTier, championId])
}

model WarBan {
  id         String   @id @default(cuid())
  warId      String
  championId Int
  createdAt  DateTime @default(now())
  champion   Champion @relation(fields: [championId], references: [id], onDelete: Cascade)
  war        War      @relation(fields: [warId], references: [id], onDelete: Cascade)

  @@index([warId])
  @@index([championId])
}

model WarFight {
  id                String          @id @default(cuid())
  createdAt         DateTime        @default(now())
  attackerId        Int?
  defenderId        Int?
  nodeId            Int
  playerId          String?
  warId             String
  videoId           String?
  battlegroup       Int
  death             Int             @default(0)
  notes             String?
  prefightChampions FightPrefight[]
  attacker          Champion?       @relation("AttackerRelation", fields: [attackerId], references: [id])
  defender          Champion?       @relation("DefenderRelation", fields: [defenderId], references: [id])
  node              WarNode         @relation(fields: [nodeId], references: [id])
  player            Player?         @relation("PlayerInFight", fields: [playerId], references: [id])
  video             WarVideo?       @relation(fields: [videoId], references: [id])
  war               War             @relation(fields: [warId], references: [id], onDelete: Cascade)

  @@index([attackerId])
  @@index([defenderId])
  @@index([nodeId])
  @@index([playerId])
  @@index([warId])
  @@index([videoId])
}

model FightPrefight {
  id         String   @id @default(cuid())
  warFightId String
  championId Int
  playerId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  champion   Champion @relation(fields: [championId], references: [id], onDelete: Cascade)
  player     Player?  @relation(fields: [playerId], references: [id])
  warFight   WarFight @relation(fields: [warFightId], references: [id], onDelete: Cascade)

  @@unique([warFightId, championId])
  @@index([warFightId])
  @@index([championId])
  @@index([playerId])
}

model WarExtraChampion {
  id          String   @id @default(cuid())
  warId       String
  playerId    String
  championId  Int
  battlegroup Int
  createdAt   DateTime @default(now())
  champion    Champion @relation(fields: [championId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  war         War      @relation(fields: [warId], references: [id], onDelete: Cascade)

  @@index([warId])
  @@index([playerId])
}

model WarVideo {
  id            String         @id @default(cuid())
  visibility    String         @default("public")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  submittedById String
  status        WarVideoStatus @default(PLANNING)
  description   String?
  gcsUrl        String?        @unique
  url           String?        @unique
  fights        WarFight[]
  submittedBy   Player         @relation("SubmittedBy", fields: [submittedById], references: [id])

  @@index([submittedById])
}

model WarNode {
  id          Int                   @id @default(autoincrement())
  nodeNumber  Int                   @unique
  description String?
  placements  WarDefensePlacement[]
  fights      WarFight[]
  allocations WarNodeAllocation[]
}

model NodeModifier {
  id                  String               @id @default(cuid())
  name                String
  description         String
  questEncounterNodes QuestEncounterNode[]
  allocations         WarNodeAllocation[]

  @@unique([name, description])
}

model WarNodeAllocation {
  id             String       @id @default(cuid())
  warNodeId      Int
  nodeModifierId String
  minTier        Int          @default(0)
  maxTier        Int          @default(0)
  season         Int          @default(0)
  mapType        WarMapType   @default(STANDARD)
  nodeModifier   NodeModifier @relation(fields: [nodeModifierId], references: [id], onDelete: Cascade)
  warNode        WarNode      @relation(fields: [warNodeId], references: [id], onDelete: Cascade)

  @@unique([warNodeId, nodeModifierId, minTier, maxTier, season, mapType])
  @@index([warNodeId])
  @@index([nodeModifierId])
}

model WarTactic {
  id           String           @id @default(cuid())
  season       Int
  minTier      Int?
  maxTier      Int?
  name         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  attackTagId  Int?
  defenseTagId Int?
  defensePlans WarDefensePlan[]
  attackTag    Tag?             @relation("AttackTactic", fields: [attackTagId], references: [id])
  defenseTag   Tag?             @relation("DefenseTactic", fields: [defenseTagId], references: [id])

  @@unique([season, minTier, maxTier])
}

model UploadSession {
  id        String   @id @default(cuid())
  token     String   @unique
  fightIds  String[]
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model UploadToken {
  id        String   @id @default(cuid())
  token     String   @unique
  playerId  String
  expiresAt DateTime
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BotJob {
  id          String       @id @default(cuid())
  type        BotJobType
  status      BotJobStatus @default(PENDING)
  payload     Json
  referenceId String?
  error       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([type, referenceId])
}

model QuestCategory {
  id           String          @id @default(cuid())
  name         String          @unique
  order        Int             @default(0)
  parentId     String?
  thumbnailUrl String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  parent       QuestCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     QuestCategory[] @relation("CategoryHierarchy")
  quests       QuestPlan[]
}

model QuestPlan {
  id              String            @id @default(cuid())
  title           String
  creatorId       String?
  categoryId      String?
  minStarLevel    Int?
  maxStarLevel    Int?
  requiredClasses ChampionClass[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  teamLimit       Int?              @default(5)
  status          QuestPlanStatus   @default(DRAFT)
  bannerUrl       String?
  bannerFit       String?           @default("cover")
  bannerPosition  String?           @default("center")
  videoUrl        String?
  playerPlans     PlayerQuestPlan[]
  encounters      QuestEncounter[]
  routeSections   QuestRouteSection[]
  category        QuestCategory?    @relation(fields: [categoryId], references: [id])
  creator         Player?           @relation("QuestCreator", fields: [creatorId], references: [id])
  creators        BotUser[]         @relation("QuestPlanCreators")
  requiredTags    Tag[]             @relation("QuestRequiredTags")
}

model QuestRouteSection {
  id          String            @id @default(cuid())
  questPlanId String
  parentPathId String?
  title       String
  order       Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  questPlan   QuestPlan         @relation(fields: [questPlanId], references: [id], onDelete: Cascade)
  parentPath  QuestRoutePath?   @relation("RouteSectionParentPath", fields: [parentPathId], references: [id], onDelete: SetNull)
  paths       QuestRoutePath[]
  choices     PlayerQuestRouteChoice[]

  @@unique([questPlanId, order])
  @@index([questPlanId])
  @@index([parentPathId])
}

model QuestRoutePath {
  id          String            @id @default(cuid())
  sectionId   String
  title       String
  order       Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  section     QuestRouteSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  childSections QuestRouteSection[] @relation("RouteSectionParentPath")
  encounters  QuestEncounter[]
  choices     PlayerQuestRouteChoice[]

  @@unique([id, sectionId])
  @@unique([sectionId, order])
  @@index([sectionId])
}

model QuestEncounter {
  id                   String                 @id @default(cuid())
  sequence             Int
  difficulty           EncounterDifficulty    @default(NORMAL)
  tips                 String?
  minStarLevel         Int?
  maxStarLevel         Int?
  requiredClasses      ChampionClass[]
  questPlanId          String
  routePathId          String?
  defenderId           Int?
  recommendedTags      String[]
  videoUrl             String?
  playerEncounters     PlayerQuestEncounter[]
  defender             Champion?              @relation(fields: [defenderId], references: [id])
  questPlan            QuestPlan              @relation(fields: [questPlanId], references: [id], onDelete: Cascade)
  routePath            QuestRoutePath?         @relation(fields: [routePathId], references: [id], onDelete: SetNull)
  nodes                QuestEncounterNode[]
  recommendedChampions Champion[]             @relation("EncounterRecommendedChampions")
  requiredTags         Tag[]                  @relation("EncounterRequiredTags")
  videos               QuestEncounterVideo[]

  @@unique([questPlanId, sequence])
  @@unique([id, questPlanId])
  @@index([questPlanId])
  @@index([routePathId])
  @@index([defenderId])
}

model QuestEncounterVideo {
  id               String         @id @default(cuid())
  questEncounterId String
  playerId         String?
  videoUrl         String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  questEncounter   QuestEncounter @relation(fields: [questEncounterId], references: [id], onDelete: Cascade)
  player           Player?        @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([questEncounterId])
  @@index([playerId])
}

model QuestEncounterNode {
  id               String         @id @default(cuid())
  questEncounterId String
  nodeModifierId   String
  nodeModifier     NodeModifier   @relation(fields: [nodeModifierId], references: [id], onDelete: Cascade)
  questEncounter   QuestEncounter @relation(fields: [questEncounterId], references: [id], onDelete: Cascade)

  @@unique([questEncounterId, nodeModifierId])
  @@index([questEncounterId])
  @@index([nodeModifierId])
}

model PlayerQuestPlan {
  id               String                       @id @default(cuid())
  playerId         String
  questPlanId      String
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  isFeatured       Boolean                      @default(false)
  encounters       PlayerQuestEncounter[]
  synergyChampions PlayerQuestSynergyChampion[]
  routeChoices     PlayerQuestRouteChoice[]
  player           Player                       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  questPlan        QuestPlan                    @relation(fields: [questPlanId], references: [id], onDelete: Cascade)

  @@unique([playerId, questPlanId])
  @@unique([id, questPlanId])
  @@index([playerId])
  @@index([questPlanId])
}

model PlayerQuestRouteChoice {
  id                  String            @id @default(cuid())
  playerQuestPlanId   String
  questRouteSectionId String
  questRoutePathId    String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  playerQuestPlan     PlayerQuestPlan   @relation(fields: [playerQuestPlanId], references: [id], onDelete: Cascade)
  questRouteSection   QuestRouteSection @relation(fields: [questRouteSectionId], references: [id], onDelete: Cascade)
  questRoutePath      QuestRoutePath    @relation(fields: [questRoutePathId], references: [id], onDelete: Cascade)

  @@unique([playerQuestPlanId, questRouteSectionId])
  @@index([playerQuestPlanId])
  @@index([questRouteSectionId])
  @@index([questRoutePathId])
}

model PlayerQuestSynergyChampion {
  id                String          @id @default(cuid())
  playerQuestPlanId String
  championId        Int
  playerQuestPlan   PlayerQuestPlan @relation(fields: [playerQuestPlanId], references: [id], onDelete: Cascade)
  champion          Champion        @relation(fields: [championId], references: [id], onDelete: Cascade)

  @@unique([playerQuestPlanId, championId])
  @@index([playerQuestPlanId])
  @@index([championId])
}

model PlayerQuestEncounter {
  id                 String          @id @default(cuid())
  playerQuestPlanId  String
  questEncounterId   String
  selectedChampionId Int?
  revivesUsed        Int             @default(0)
  questPlanId        String
  playerQuestPlan    PlayerQuestPlan @relation(fields: [playerQuestPlanId, questPlanId], references: [id, questPlanId], onDelete: Cascade)
  questEncounter     QuestEncounter  @relation(fields: [questEncounterId, questPlanId], references: [id, questPlanId], onDelete: Cascade)
  selectedChampion   Champion?       @relation("PlayerSelectedCounter", fields: [selectedChampionId], references: [id])

  @@unique([playerQuestPlanId, questEncounterId])
  @@index([playerQuestPlanId])
  @@index([questEncounterId])
  @@index([selectedChampionId])
}

