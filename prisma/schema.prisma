  SCIENCE
  SKILL
  MYSTIC
  COSMIC
  TECH
  MUTANT
  SUPERIOR
}

enum AbilityLinkType {
  ABILITY
  IMMUNITY
}

enum AttackType {
  L1
  L2
  L3
  L4
  M1
  M2
  H
  S1
  S2
}

enum WarResult {
