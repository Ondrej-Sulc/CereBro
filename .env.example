NODE_ENV=production/development

# Discord Bot
# Base URL for the web application (used for generating links)
BOT_BASE_URL="http://localhost:3000"
DISCORD_BOT_TOKEN_PROD=your-bot-token-here
DISCORD_BOT_TOKEN_DEV=your-bot-token-dev-here
# OAuth2 Credentials
DISCORD_CLIENT_ID=your-discord-client-id-here
DISCORD_CLIENT_SECRET=your-discord-client-secret-here

# OpenRouter (AI integration)
OPEN_ROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_DEFAULT_MODEL=google/gemini-pro

# Google Sheets Integration
# Full JSON credentials for Google service account encoded into base 64
GOOGLE_CREDENTIALS_JSON=your-encoded-json-into-base64
MCOC_SHEET_ID=your-mcoc-sheet-id-here
CHAMPION_SHEET_ID=your-champion-sheet-id-here

# YouTube API for Video Uploads
# WARNING: Keep these credentials secure. YOUTUBE_REFRESH_TOKEN provides persistent access to your YouTube account.
YOUTUBE_CLIENT_ID=your-youtube-client-id-here
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret-here
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token-here

# Optional: Developer User IDs for debug commands (comma-separated)
DEV_USER_IDS=your-user-id,another-user-id

# PostHog (Analytics)
POSTHOG_API_KEY=
POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Stripe (Support Donations)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_SUPPORT_CURRENCY=eur
# STRIPE_SUPPORT_MIN_AMOUNT and STRIPE_SUPPORT_MAX_AMOUNT are in minor units (e.g., cents for EUR/USD).   
# Minimum is 50 (EUR/USD 0.50). Example: 50 = €0.50, 1000 = €10.00.
STRIPE_SUPPORT_MIN_AMOUNT=50
# Use minor units for max amount too (e.g., 1000 = €10.00, 100000 = €1000.00).
STRIPE_SUPPORT_MAX_AMOUNT=1000

# Support Server Roles
SUPPORT_SERVER_ID=your-support-server-guild-id
SUPPORT_ROLE_ID=your-supporter-role-id
# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mydb